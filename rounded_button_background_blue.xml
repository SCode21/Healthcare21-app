<!-- res/drawable/rounded_button_background_blue.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Define the background color -->
    <solid android:color="#2196F3" /> <!-- Blue color -->

    <!-- Define rounded corners -->
    <corners android:radius="12dp" /> <!-- Adjust the radius as needed -->

    <!-- Optional: Add a stroke (border) -->
    <stroke
        android:width="2dp"
        android:color="#1976D2" /> <!-- Darker blue border -->
</shape>