<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F3E5F5">

    <TextView
        android:id="@+id/dashboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Doctor Dashboard"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#4A148C"
        android:paddingBottom="20dp" />

    <TextView
        android:id="@+id/totalAppointments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Appointments: 0"
        android:textSize="18sp"
        android:textColor="#333" />

    <TextView
        android:id="@+id/pendingAppointments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pending: 0"
        android:textSize="18sp"
        android:textColor="#333" />

    <TextView
        android:id="@+id/completedAppointments"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completed: 0"
        android:textSize="18sp"
        android:textColor="#333" />

    <TextView
        android:id="@+id/totalPatients"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total Patients: 0"
        android:textSize="18sp"
        android:textColor="#333" />

    <TextView
        android:id="@+id/nextAppointment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Next: N/A"
        android:textSize="18sp"
        android:textColor="#333"
        android:paddingBottom="20dp" />

    <Button
        android:id="@+id/viewAppointmentsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Appointments"
        android:backgroundTint="#7B1FA2"
        android:textColor="#FFF" />

    <Button
        android:id="@+id/managePatientsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage Patients"
        android:backgroundTint="#7B1FA2"
        android:textColor="#FFF"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/logoutButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFF"
        android:layout_marginTop="10dp" />

</LinearLayout>
